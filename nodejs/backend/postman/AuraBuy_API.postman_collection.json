{
  "info": {
    "name": "AuraBuy Node.js API",
    "description": "Postman collection for AuraBuy migrated Node.js backend (via Gateway: http://localhost:8000/api or direct: http://localhost:8081)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "gatewayUrl", "value": "http://localhost:8000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "courseId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "reviewId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Auth Test",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/test" }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('accessToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@aurabuy.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@aurabuy.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products" }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"Sample product\",\n  \"price\": 99.99,\n  \"rating\": 4.5,\n  \"category\": \"Electronics\",\n  \"imageUrl\": \"https://images.unsplash.com/photo-1505740420928-5e560c06d30e\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Product By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/{{productId}}" }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product\",\n  \"description\": \"Updated\",\n  \"price\": 109.99,\n  \"rating\": 4.7,\n  \"category\": \"Electronics\",\n  \"imageUrl\": \"\"\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "Get All Categories", "request": { "method": "GET", "url": "{{baseUrl}}/categories" } },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"categoryName\": \"Books\"\n}" },
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        { "name": "Get All Courses", "request": { "method": "GET", "url": "{{baseUrl}}/courses" } },
        {
          "name": "Create Course (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Node.js Basics\",\n  \"description\": \"Learn Node.js\",\n  \"difficulty\": \"Beginner\",\n  \"category\": \"Programming\"\n}"
            },
            "url": "{{baseUrl}}/courses"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search All",
          "request": { "method": "GET", "url": "{{baseUrl}}/search?query=headphones" }
        },
        {
          "name": "Search with Filters",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/search?query=wireless&category=Electronics&sortBy=price&sortOrder=asc&page=1&limit=10"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [{ \"product\": \"{{productId}}\", \"quantity\": 1 }]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"{{productId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent product!\"\n}"
            },
            "url": "{{baseUrl}}/reviews"
          }
        },
        { "name": "Get All Reviews", "request": { "method": "GET", "url": "{{baseUrl}}/reviews" } }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users"
          }
        }
      ]
    }
  ]
}
