PORT=8081
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/aurabuy_db?retryWrites=true&w=majority
JWT_SECRET=your_jwt_access_secret_key_at_least_32_chars_long
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_chars_long
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development
